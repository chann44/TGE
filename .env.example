# Core service config
DB_HOST=postgres
DB_PORT=5432
DB_USER=dev
DB_PASSWORD=dev
DB_NAME=app

REDIS_HOST=redis
REDIS_PORT=6379

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=default

# Public URLs
FRONTEND_URL=http://localhost:3000
API_PORT=8080
WEB_PORT=3000

# Optional vulnerability API credentials
GHSA_API_TOKEN=
NVD_API_KEY=

# Optional advanced supply-chain scanning
SUPPLY_CHAIN_ENABLED=false

# Optional image override for self-host compose
# TGE_BACKEND_IMAGE=chann44/tge-backend:latest
# TGE_WEB_IMAGE=chann44/tge-web:latest

# GitHub OAuth / App integration (optional for first boot, needed for GitHub features)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/v1/auth/github/callback
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_APP_INSTALL_URL=
